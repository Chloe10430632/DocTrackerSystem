<!DOCTYPE html>
<html lang="zh-hant-TW">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] | DocTracker</title>
    <!-- 網頁標籤icon -->
    <link rel="icon" href="~/favicon.ico">
    <!-- 掛載 Tabler CSS -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@@tabler/core@1.4.0/dist/css/tabler.min.css" />
    <!-- 掛載 Bootstrap 5 Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">
    <!-- Google Font -->
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@100..900&display=swap" rel="stylesheet">
    <!--Animate 動畫 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
    <!-- Layout的自訂樣式 -->
    <link rel="stylesheet" href="~/css/layout.css">
    @RenderSection("Link", false)
    @RenderSection("Style", false)
</head>

<body>

    <div class="page">
        <!-- 左側選單按鈕 -->
        <aside class="navbar navbar-vertical navbar-expand-lg">
            <div class="container ">
                <!-- 手機板menu漢堡按鈕 -->
                <button class="navbar-toggler d-lg-none" type="button" data-bs-toggle="collapse"
                        data-bs-target="#sidebar-menu" aria-controls="sidebar-menu" aria-expanded="false"
                        aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <!-- Logo 圖片 -->
                <div class="navbar-brand py-4 mx-auto">
                    <a href="/Home/Index">
                        <img src="~/imgs/salter-logo.svg" width="150px" alt="Salter Logo"
                             style="position: relative; left: -13px;">
                    </a>
                </div>
                <!-- 選單按鈕 -->
                <div class="collapse navbar-collapse" id="sidebar-menu">
                    <ul class="navbar-nav pt-3">

                        
                        <!-- 閱讀文件 -->
                        <li class="nav-item mb-3">
                            <a class="nav-link me-3" asp-area="" asp-controller="Document" asp-action="Index">
                                <i class="bi bi-person-fill-gear fs-1 fw-bold ps-3"></i>
                                <span class="ps-5 nav-link-title">閱讀文件</span>
                            </a>
                        </li>

                        <!-- 查詢紀錄 -->
                        <li class="nav-item mb-3">
                            <a class="nav-link me-3" asp-area="" asp-controller="Document" asp-action="Index">
                                <i class="bi bi-person-fill-gear fs-1 fw-bold ps-3"></i>
                                <span class="ps-5 nav-link-title">閱讀文件</span>
                            </a>
                        </li>

                    </ul>
                </div>
            </div>
        </aside>
        <!-- 右側主內容畫面 -->
        <div class="page-wrapper bg-gray-200">
            <!-- 導覽列 -->
            <header class="navbar navbar-expand-md d-print-none py-2 bg-primary sticky-top bg-cyan" >
                <div class="container">
                    <div class="row px-5">
                        <h2 class="text-white ms-5">文件閱讀系統</h2>
                    </div>
                    
                    
                    <!-- 目前登入者 -->
                    @if (User.FindFirst("UserId")?.Value != null)
                    {
                        <div class="navbar-nav flex-row order-md-last">
                        <div class="nav-item dropdown">
                            <a href="#" class="nav-link d-flex lh-1 text-reset" data-bs-toggle="dropdown"
                               aria-label="Open user menu">
                                @{
                                    var userId = User.FindFirst("UserId")?.Value;
                                    var avatarUrl = string.IsNullOrEmpty(userId)
                                    ? Url.Content("~/imgs/peach.jpg")
                                    : User.FindFirst("Avatar")?.Value;
                                }
                                <span class="avatar avatar-sm" style="background-image: url('@avatarUrl'); background-position: top center;"></span>
                                <div class="d-none d-xl-block ps-2">
                                        <div class="text-white">@User.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value</div>
                                    <div class="mt-1 small fs-4 text-white">@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</div>
                                </div>
                            </a>
                            <div class="dropdown-menu dropdown-menu-end dropdown-menu-arrow">
                                <a asp-area="" asp-controller="Login" asp-action="Logout" class="dropdown-item">登出</a>
                            </div>
                        </div>
                        </div>
                    }
                    else
                    {
                        <div class="navbar-nav flex-row order-md-last">
                            <div class="nav-item dropdown">
                                    <a asp-area="" asp-controller="Login" asp-action="Login" class="dropdown-item text-white">登入</a>
                            </div>
                        </div>
                    }

                </div>
            </header>
            <!-- 主要管理內容 -->
            <div class="container-fluid">
                <main role="main" class="pb-5">
                    @RenderBody()
                    @await RenderSectionAsync("UserListStyles", required: false)
                </main>
            </div>
        </div>
    </div>




    <!-- 掛載 jQuery -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <!-- 掛載 Tabler JS -->
    <script src="https://cdn.jsdelivr.net/npm/@@tabler/core@1.4.0/dist/js/tabler.min.js"></script>
    <!-- 掛載 Wow JS -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/wow/1.1.2/wow.min.js"></script>
    <!-- 掛載 自訂js腳本 -->
    <script src="/js/layout.js?v=1.1"></script>


    @*@await RenderSectionAsync("Scripts", required: false) *@
    @RenderSection("Scripts", false)
</body>
</html>
